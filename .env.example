# Supabase cloud sync (optional — the app works without it).
# Project settings: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Email of the single shared team account created in Supabase Auth.
# Everyone signs in with this email + the team password you set.
NEXT_PUBLIC_SUPABASE_SHARED_EMAIL=team@qubeplot.app
